{
  "name": "@waeasi/sdk",
  "version": "0.1.0",
  "description": "Official WAeasi SDK — write WAeasi components in TypeScript with the Fetch API.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "waeasi": "./dist/cli/main.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build/pipeline.d.ts",
      "import": "./dist/build/pipeline.js"
    },
    "./wasi": {
      "types": "./dist/wasi/index.d.ts",
      "import": "./dist/wasi/index.js"
    }
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx test/**/*.test.ts",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20.10.0"
  },
  "dependencies": {
    "@bytecodealliance/componentize-js": "^0.18.0",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "waeasi",
    "wasm",
    "wasi",
    "component-model",
    "edge",
    "serverless",
    "microkernel"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/waeasi/waeasi"
  },
  "publishConfig": {
    "access": "public"
  }
}
